# ─── Base de dados (Supabase) ─────────────────────────────────────────────────
# Project Settings > Database > Connection method > "Session pooler" > URI
#
# Usa Session pooler (porta 5432) para AMBOS DATABASE_URL e DIRECT_URL:
# - IPv4 (compatível com Netlify Functions)
# - Suporta prepared statements, por isso serve para runtime E migrações
# - Dispensa flags pgbouncer
#
# (Alternativa: Transaction pooler 6543 é mais eficiente mas usa IPv6 por
# default — só funciona em Netlify se activares o IPv4 add-on pago.)
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# Gera com: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="https://app.lectiva.pt"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://app.lectiva.pt"
NEXT_PUBLIC_APP_DOMAIN="app.lectiva.pt"
NEXT_PUBLIC_APP_NAME="Lectiva"

# ─── Cloudflare R2 (file storage) ─────────────────────────────────────────────
# Cria bucket + token em https://dash.cloudflare.com/?to=/:account/r2
# O bucket deve ter acesso público de leitura no R2_PUBLIC_URL (custom domain
# preferível, ou pub-xxxx.r2.dev em dev).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="lectiva-files"
R2_PUBLIC_URL="https://cdn.lectiva.pt"

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Gera uma vez: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@lectiva.pt"
# Igual ao VAPID_PUBLIC_KEY (exposto ao cliente para subscribe)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ─── Email transacional (Resend) ──────────────────────────────────────────────
# https://resend.com — cria conta, verifica o domínio (SPF + DKIM), gera API key.
# Em dev podes deixar vazio: envios são SKIPPED, app continua a funcionar.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Lectiva <noreply@lectiva.pt>"
RESEND_REPLY_TO="suporte@lectiva.pt"

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
# https://twilio.com — Messaging Service é o recomendado (sender ID alfanumérico).
# Em dev podes deixar vazio: SMS são SKIPPED; a API de verificação telefónica
# devolve o código no JSON da resposta (NÃO seguro em prod, deixa vazio se não
# queres SMS reais).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""
TWILIO_FROM_NUMBER=""

# ─── Sentry (error tracking — recomendado em produção) ────────────────────────
# https://sentry.io — cria projeto Next.js, copia o DSN.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
